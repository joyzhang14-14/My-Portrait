+        // 有序最长公共子序列长度(滚动数组);两边裁到尾部上限控成本。
+        func lcs(_ a: [Character], _ b: [Character]) -> Int {
+            if a.isEmpty || b.isEmpty { return 0 }
+            var dp = [Int](repeating: 0, count: b.count + 1)
+            for ca in a {
+                var prev = 0
+                for j in 0..<b.count {
+                    let keep = dp[j + 1]
+                    dp[j + 1] = ca == b[j] ? prev + 1 : max(dp[j + 1], dp[j])
+                    prev = keep
+                }
+            }
+            return dp[b.count]
+        }
+        func simRatio(_ a: String, _ b: String) -> Double {
